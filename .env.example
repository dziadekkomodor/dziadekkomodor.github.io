# Copy this file to .env and fill in real values before Stage 2/3. Astro only exposes
# PUBLIC_-prefixed vars to client-side code, which is required here since the contact form
# submits directly from the browser (no backend on GitHub Pages).

# Discord webhook URL that receives contact-form submissions. Left empty through Stage 1 —
# ContactForm.astro handles the empty case gracefully (form shows a "test mode" notice instead
# of throwing a fetch error). Created in Stage 2 once a Discord server/channel exists for this.
PUBLIC_DISCORD_WEBHOOK_URL=
