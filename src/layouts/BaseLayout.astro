---
import '../styles/global.css';
import { site } from '../data/site';
import { getImage } from 'astro:assets';
import logoSrc from '../assets/photos/logo2-cropped.png';
import frauncesFontUrl from '@fontsource-variable/fraunces/files/fraunces-latin-soft-normal.woff2?url';
import atkinsonFontUrl from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-400-normal.woff2?url';
import atkinson700FontUrl from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-700-normal.woff2?url';

const favicon = await getImage({ src: logoSrc, width: 192, height: 192, format: 'png' });

export interface Props {
  lang: "pl" | "en";
  title: string;
  description: string;
  /** Locale-agnostic slug, e.g. "cennik" or "" for the homepage — used to build hreflang alternates. */
  slug: string;
  /** One JSON-LD object, or an array of them (each gets its own <script> tag). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  theme?: "gaming";
  density?: "comfortable";
}

const { lang, title, description, slug, jsonLd, theme, density } = Astro.props;

const plPath = slug ? `/${slug}` : "/";
const enPath = slug ? `/en/${slug}` : "/en/";
const canonicalPath = lang === "en" ? enPath : plPath;
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const plUrl = new URL(plPath, site.url).toString();
const enUrl = new URL(enPath, site.url).toString();

const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

---

<!doctype html>
<html lang={lang} data-theme={theme} data-density={density}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href={favicon.src} sizes="192x192" />
		<link rel="apple-touch-icon" href={favicon.src} />
		<title>{title} — {site.brandName}</title>
		<meta name="description" content={description} />
		<link rel="preload" href={frauncesFontUrl} as="font" type="font/woff2" crossorigin />
		<link rel="preload" href={atkinsonFontUrl} as="font" type="font/woff2" crossorigin />
		<link rel="preload" href={atkinson700FontUrl} as="font" type="font/woff2" crossorigin />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="pl" href={plUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="x-default" href={plUrl} />
		<meta property="og:title" content={`${title} — ${site.brandName}`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		{jsonLdBlocks.map((block) => (
			<script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
		))}
	</head>
	<body>
		<div id="page-progress" aria-hidden="true"></div>
		<a href="#main-content" class="skip-link">
			{lang === "en" ? "Skip to content" : "Przejdź do treści"}
		</a>
		<slot />
		<script src="/src/scripts/motion.js"></script>
		<script src="/src/scripts/page-loading.js"></script>
		<script src="/src/scripts/copy-contact.js"></script>
	</body>
</html>
