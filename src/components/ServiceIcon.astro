---
// Small per-service icon for the "Usługi" nav dropdown — keyed by services.ts slug, one
// consistent stroke style matching the rest of the site's inline SVGs.

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

{slug === "naprawa-laptopow-i-komputerow" && (
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
		<rect x="4" y="4" width="16" height="11" rx="1" />
		<path d="M2 18h20l-1.5 2h-17z" />
	</svg>
)}
{slug === "naprawa-telefonow-i-tabletow" && (
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
		<rect x="7" y="2.5" width="10" height="19" rx="2" />
		<path d="M10.5 18.5h3" />
	</svg>
)}
{slug === "komputery-gamingowe-bydgoszcz" && (
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
		<rect x="2" y="8" width="20" height="10" rx="4" />
		<path d="M7 11v4M5 13h4" />
		<circle cx="16" cy="12" r="0.8" fill="currentColor" stroke="none" />
		<circle cx="18.5" cy="14.5" r="0.8" fill="currentColor" stroke="none" />
	</svg>
)}
{slug === "uslugi-it-dla-firm" && (
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
		<rect x="3" y="7" width="18" height="12" rx="1.5" />
		<path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" />
	</svg>
)}
{slug === "pomoc-komputerowa-seniorzy" && (
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
		<circle cx="12" cy="8" r="3.2" />
		<path d="M5 20c1-3.5 4-5.5 7-5.5s6 2 7 5.5" />
	</svg>
)}
