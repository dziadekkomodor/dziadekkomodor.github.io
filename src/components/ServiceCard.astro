---
export interface Props {
  href: string;
  persona: string;
  title: string;
  short: string;
  featured?: boolean;
  theme?: "gaming";
}

const { href, persona, title, short, featured = false, theme } = Astro.props;
---

<a href={href} class="service-card" class:list={{ 'service-card--featured': featured }} data-theme={theme}>
	<span class="service-card__persona">{persona}</span>
	<h3>{title}</h3>
	<p>{short}</p>
	<span class="service-card__arrow" aria-hidden="true">→</span>
</a>

<style>
	.service-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: var(--space-4);
		background: var(--color-bg-raised);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sharp);
		text-decoration: none;
		color: var(--color-ink);
		transition: transform var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
	}

	.service-card:hover {
		transform: translateY(-3px);
		border-color: var(--color-accent);
	}

	.service-card__persona {
		font-size: var(--text-xs);
		font-weight: var(--weight-body-bold);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-accent);
	}

	.service-card h3 {
		margin: var(--space-2) 0 var(--space-2);
		font-size: var(--text-lg);
	}

	.service-card--featured h3 {
		font-size: var(--text-2xl);
		max-width: 14ch;
	}

	.service-card p {
		margin: 0;
		color: var(--color-ink-soft);
		font-size: var(--text-sm);
		flex-grow: 1;
	}

	.service-card--featured p {
		font-size: var(--text-body);
		max-width: 40ch;
	}

	.service-card__arrow {
		margin-top: var(--space-3);
		font-family: var(--font-headline);
		font-weight: var(--weight-headline-black);
		color: var(--color-accent);
	}
</style>
