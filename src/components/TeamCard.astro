---
import PlaceholderImage from './PlaceholderImage.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  lang: "pl" | "en";
  name: string;
  role: string;
  bio: string;
  yearsExperience: number;
  compact?: boolean;
  photo?: ImageMetadata;
}

const { lang, name, role, bio, yearsExperience, compact = false, photo } = Astro.props;
const yearsLabel = lang === "en"
  ? `${yearsExperience}+ years of experience`
  : `${yearsExperience}+ lat doświadczenia`;
---

<article class="team-card">
	{photo ? (
		<Image src={photo} alt={name} width={480} height={480} format="webp" class="team-card__photo" />
	) : (
		<PlaceholderImage lang={lang} captionPl={`Zdjęcie: ${name}`} captionEn={`Photo: ${name}`} ratio="1 / 1" />
	)}
	<h3>{name}</h3>
	<p class="team-card__meta">{role} · {yearsLabel}</p>
	{!compact && <p class="team-card__bio">{bio}</p>}
</article>

<style>
	.team-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.team-card__photo {
		width: 100%;
		height: auto;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: var(--radius-soft);
	}

	.team-card h3 {
		margin: 0;
		font-size: var(--text-xl);
	}

	.team-card__meta {
		margin: 0;
		font-size: var(--text-sm);
		font-weight: var(--weight-body-bold);
		color: var(--color-accent);
	}

	.team-card__bio {
		margin: 0;
		color: var(--color-ink-soft);
	}
</style>
