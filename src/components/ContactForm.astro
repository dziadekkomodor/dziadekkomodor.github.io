---
import { localePath } from '../data/nav';

export interface Props {
  lang: "pl" | "en";
}

const { lang } = Astro.props;
const privacyHref = localePath(lang, "polityka-prywatnosci");

const t = lang === "en"
  ? {
      name: "Full name",
      namePlaceholder: "Jane Smith",
      contact: "Phone or email",
      contactPlaceholder: "500 000 000 or you@email.com",
      location: "Where are you located?",
      locationOptions: [
        { value: "pila", label: "Piła" },
        { value: "bydgoszcz", label: "Bydgoszcz" },
        { value: "okolica", label: "Nearby" },
      ],
      locationOtherLabel: "Which town?",
      locationOtherPlaceholder: "e.g. Wyrzysk",
      device: "Device type",
      deviceOptions: [
        { key: "not-sure", label: "Not sure" },
        { key: "laptop", label: "Laptop" },
        { key: "desktop", label: "Desktop computer" },
        { key: "phone", label: "Phone" },
        { key: "gaming-pc", label: "Gaming PC" },
        { key: "other", label: "Other" },
      ],
      problem: "Briefly describe the problem",
      problemPlaceholder: "e.g. the laptop overheats and runs loudly",
      progressLabel: "Form progress",
      transport: "How will the device get to us?",
      transportOptions: [
        { value: "wysylka", label: "I'll send it", note: "You cover the shipping cost." },
        { value: "dowoz", label: "I'll drop it off (Wyrzysk)", note: "Free — we'll share the exact address once we're in touch." },
        { value: "odbior", label: "You pick it up", note: "Fuel cost there-and-back + 12 zł. We confirm availability after contact — not always possible right away." },
      ],
      photo: "Photo (optional)",
      consentPre: "I agree to the processing of my data per the ",
      consentLink: "privacy policy",
      consentPost: ".",
      submit: "Send request",
      submitting: "Sending…",
      success: "Thanks — we've received your request and will get back to you shortly. If it's urgent, just call us.",
      error: "Something went wrong sending the form. Please call or email us directly instead.",
      testMode: "Contact form is in test mode during local development — submissions aren't sent anywhere yet.",
    }
  : {
      name: "Imię i nazwisko",
      namePlaceholder: "Jan Kowalski",
      contact: "Telefon lub e-mail",
      contactPlaceholder: "500 000 000 lub ty@email.com",
      location: "Gdzie jesteś?",
      locationOptions: [
        { value: "pila", label: "Piła" },
        { value: "bydgoszcz", label: "Bydgoszcz" },
        { value: "okolica", label: "Okolica" },
      ],
      locationOtherLabel: "Jaka miejscowość?",
      locationOtherPlaceholder: "np. Wyrzysk",
      device: "Rodzaj urządzenia",
      deviceOptions: [
        { key: "not-sure", label: "Nie jestem pewien/pewna" },
        { key: "laptop", label: "Laptop" },
        { key: "desktop", label: "Komputer stacjonarny" },
        { key: "phone", label: "Telefon" },
        { key: "gaming-pc", label: "Komputer gamingowy" },
        { key: "other", label: "Inne" },
      ],
      problem: "Krótko opisz problem",
      problemPlaceholder: "np. laptop się przegrzewa i głośno pracuje",
      progressLabel: "Postęp wypełniania formularza",
      transport: "Jak sprzęt do nas trafi?",
      transportOptions: [
        { value: "wysylka", label: "Wyślę sam/a", note: "Koszt przesyłki jest po Twojej stronie." },
        { value: "dowoz", label: "Dowiozę osobiście (Wyrzysk)", note: "Bezpłatnie — dokładny adres podamy po kontakcie." },
        { value: "odbior", label: "Odbierzcie ode mnie", note: "Koszt paliwa (dojazd i powrót) + 12 zł. Dostępność potwierdzamy po kontakcie — nie zawsze jest możliwe od razu." },
      ],
      photo: "Zdjęcie (opcjonalnie)",
      consentPre: "Wyrażam zgodę na przetwarzanie moich danych zgodnie z ",
      consentLink: "polityką prywatności",
      consentPost: ".",
      submit: "Wyślij zgłoszenie",
      submitting: "Wysyłanie…",
      success: "Dziękujemy — otrzymaliśmy Twoje zgłoszenie i wkrótce się odezwiemy. Jeśli sprawa jest pilna, po prostu zadzwoń.",
      error: "Coś poszło nie tak przy wysyłce formularza. Zadzwoń lub napisz do nas bezpośrednio.",
      testMode: "Formularz kontaktowy działa w trybie testowym podczas lokalnego developmentu — zgłoszenia nie są jeszcze nigdzie wysyłane.",
    };
---

<form class="contact-form" id="contact-form" novalidate data-lang={lang}>
	<div class="contact-form__progress-track" role="progressbar" aria-label={t.progressLabel} aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" id="cf-progress">
		<div class="contact-form__progress-fill" id="cf-progress-fill"></div>
	</div>

	<div class="contact-form__field">
		<label for="cf-name">{t.name} <span aria-hidden="true">*</span></label>
		<input id="cf-name" name="name" type="text" required autocomplete="name" maxlength="100" placeholder={t.namePlaceholder} />
	</div>

	<div class="contact-form__field">
		<label for="cf-contact">{t.contact} <span aria-hidden="true">*</span></label>
		<input id="cf-contact" name="contact" type="text" required autocomplete="tel" maxlength="100" aria-describedby="cf-contact-error" placeholder={t.contactPlaceholder} />
		<span class="contact-form__error" id="cf-contact-error" role="alert"></span>
	</div>

	<div class="contact-form__field">
		<span class="contact-form__group-label">{t.location} <span aria-hidden="true">*</span></span>
		<div class="contact-form__pills" role="radiogroup" aria-label={t.location}>
			{t.locationOptions.map((opt) => (
				<div class="contact-form__pill">
					<input type="radio" name="location" id={`cf-location-${opt.value}`} value={opt.label} data-value={opt.value} required />
					<label for={`cf-location-${opt.value}`}>{opt.label}</label>
				</div>
			))}
		</div>
		<div class="contact-form__field contact-form__conditional" id="cf-location-other-wrap" hidden>
			<label for="cf-location-other">{t.locationOtherLabel}</label>
			<input id="cf-location-other" name="location-other" type="text" maxlength="60" placeholder={t.locationOtherPlaceholder} />
		</div>
	</div>

	<div class="contact-form__field">
		<label for="cf-device">{t.device} <span aria-hidden="true">*</span></label>
		<select id="cf-device" name="device" required>
			{t.deviceOptions.map((opt) => <option value={opt.label} data-key={opt.key}>{opt.label}</option>)}
		</select>
	</div>

	<div class="contact-form__field">
		<div class="contact-form__label-row">
			<label for="cf-problem">{t.problem} <span aria-hidden="true">*</span></label>
			<span class="contact-form__counter" id="cf-problem-counter" aria-hidden="true">0/500</span>
		</div>
		<textarea id="cf-problem" name="problem" rows="3" required maxlength="500" placeholder={t.problemPlaceholder}></textarea>
	</div>

	<div class="contact-form__field">
		<span class="contact-form__group-label">{t.transport} <span aria-hidden="true">*</span></span>
		<div class="contact-form__pills contact-form__pills--stack" role="radiogroup" aria-label={t.transport}>
			{t.transportOptions.map((opt) => (
				<div class="contact-form__pill contact-form__pill--wide">
					<input type="radio" name="transport" id={`cf-transport-${opt.value}`} value={opt.label} required />
					<label for={`cf-transport-${opt.value}`}>
						<span class="contact-form__pill-title">{opt.label}</span>
						<span class="contact-form__pill-note">{opt.note}</span>
					</label>
				</div>
			))}
		</div>
	</div>

	<div class="contact-form__field">
		<label for="cf-photo">{t.photo}</label>
		<input id="cf-photo" name="photo" type="file" accept="image/*" />
	</div>

	<!-- Honeypot: real users never see or fill this. Off-screen (not display:none — some bots
	     skip display:none but still fill off-screen fields, so this catches more of them), never
	     reachable by keyboard, hidden from screen readers. -->
	<div class="hp-field" aria-hidden="true">
		<label for="cf-website">Website</label>
		<input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
	</div>

	<div class="contact-form__field contact-form__consent">
		<input id="cf-consent" name="consent" type="checkbox" required />
		<label for="cf-consent">
			{t.consentPre}<a href={privacyHref}>{t.consentLink}</a>{t.consentPost}
		</label>
	</div>

	<button type="submit" class="btn btn-primary">{t.submit}</button>

	<p class="contact-form__status" role="status" aria-live="polite"></p>
</form>

<style>
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		max-width: 34rem;
	}

	.contact-form__progress-track {
		height: 8px;
		border-radius: var(--radius-pill);
		background: var(--color-border);
		overflow: hidden;
	}

	.contact-form__progress-fill {
		height: 100%;
		width: 0%;
		background: var(--color-accent);
		border-radius: var(--radius-pill);
		transition: width var(--duration-base) var(--ease-out);
	}

	.contact-form__label-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-3);
	}

	.contact-form__counter {
		font-size: var(--text-xs);
		color: var(--color-ink-soft);
		font-weight: var(--weight-body-regular);
		white-space: nowrap;
	}

	.contact-form__error {
		font-size: var(--text-xs);
		font-weight: var(--weight-body-bold);
		color: #B3261E;
	}

	.contact-form__error:empty {
		display: none;
	}

	.contact-form__field {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	/* Author styles always beat the browser's own [hidden]{display:none} default at equal
	   specificity/importance — without this, .contact-form__field's own `display: flex` silently
	   wins and the hidden attribute stops doing anything visually, even though the DOM property
	   is set correctly. This is what was making the "Jaka miejscowość?" field stay visible. */
	.contact-form__field[hidden] {
		display: none;
	}

	.contact-form label,
	.contact-form__group-label {
		font-weight: var(--weight-body-bold);
		font-size: var(--text-sm);
	}

	.contact-form input[type="text"],
	.contact-form input[type="file"],
	.contact-form select,
	.contact-form textarea {
		padding: var(--space-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sharp);
		background: var(--color-bg-raised);
		color: var(--color-ink);
	}

	.contact-form input[type="text"]::placeholder,
	.contact-form textarea::placeholder {
		color: var(--color-ink-soft);
	}

	.contact-form__conditional {
		margin-top: var(--space-2);
	}

	.contact-form__pills {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.contact-form__pills--stack {
		flex-direction: column;
		align-items: stretch;
	}

	.contact-form__pill input {
		position: absolute;
		opacity: 0;
		width: 1px;
		height: 1px;
	}

	.contact-form__pill label {
		display: inline-flex;
		align-items: center;
		padding: 0.55em 1.1em;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		font-weight: var(--weight-body-bold);
		font-size: var(--text-sm);
		cursor: pointer;
		background: var(--color-bg-raised);
		transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
	}

	.contact-form__pill input:checked + label {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: var(--color-accent-ink);
	}

	.contact-form__pill input:focus-visible + label {
		outline: 3px solid var(--color-accent);
		outline-offset: 2px;
	}

	.contact-form__pill--wide label {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.25em;
		border-radius: var(--radius-soft);
		padding: var(--space-3);
		width: 100%;
	}

	.contact-form__pill-title {
		font-weight: var(--weight-body-bold);
		font-size: var(--text-sm);
	}

	.contact-form__pill-note {
		font-weight: var(--weight-body-regular);
		font-size: var(--text-xs);
	}

	.contact-form__pill--wide input:checked + label .contact-form__pill-note {
		color: var(--color-accent-ink);
		opacity: 0.9;
	}

	.contact-form__pill--wide input:not(:checked) + label .contact-form__pill-note {
		color: var(--color-ink-soft);
	}

	.contact-form__consent {
		flex-direction: row;
		align-items: flex-start;
		gap: var(--space-3);
	}

	.contact-form__consent label {
		font-weight: var(--weight-body-regular);
	}

	.contact-form__consent input {
		margin-top: 0.3em;
	}

	.contact-form button {
		align-self: flex-start;
	}

	.contact-form__status {
		margin: 0;
		font-weight: var(--weight-body-bold);
	}

	.contact-form__status[data-state="success"] {
		color: #2E7D32;
	}

	.contact-form__status[data-state="error"] {
		color: #B3261E;
	}
</style>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;

	if (form) {
		const lang = form.dataset.lang === 'en' ? 'en' : 'pl';

		// Pre-select the device dropdown when arriving from a persona page's "Darmowa wycena" CTA
		// (e.g. /kontakt?device=laptop) — a plain URL param since this is a static multi-page site,
		// not a hidden default: the user can still change it, this just saves the obvious pick.
		const deviceHint = new URLSearchParams(location.search).get('device');
		if (deviceHint) {
			const deviceSelect = document.getElementById('cf-device') as HTMLSelectElement | null;
			const match = deviceSelect?.querySelector<HTMLOptionElement>(`option[data-key="${deviceHint}"]`);
			if (deviceSelect && match) {
				deviceSelect.value = match.value;
			}
		}

		// Reveal a free-text "which town?" field only when "Okolica/Nearby" is picked — required
		// only while it's actually visible, so it never blocks submission when hidden.
		const locationRadios = form.querySelectorAll<HTMLInputElement>('input[name="location"]');
		const otherWrap = document.getElementById('cf-location-other-wrap') as HTMLDivElement | null;
		const otherInput = document.getElementById('cf-location-other') as HTMLInputElement | null;

		function syncLocationOther() {
			const checked = form!.querySelector<HTMLInputElement>('input[name="location"]:checked');
			const isOkolica = checked?.dataset.value === 'okolica';
			if (otherWrap) otherWrap.hidden = !isOkolica;
			if (otherInput) {
				otherInput.required = !!isOkolica;
				if (!isOkolica) otherInput.value = '';
			}
		}

		locationRadios.forEach((radio) => radio.addEventListener('change', syncLocationOther));
		syncLocationOther();

		// Live character count on the problem field only (per its own maxlength) — the other
		// maxlength attributes (name/contact/location-other) just cap length quietly, keeping a
		// stray paste or a spam attempt from blowing up the Discord message.
		const problemField = document.getElementById('cf-problem') as HTMLTextAreaElement | null;
		const problemCounter = document.getElementById('cf-problem-counter');

		function updateProblemCounter() {
			if (problemField && problemCounter) {
				problemCounter.textContent = `${problemField.value.length}/${problemField.maxLength}`;
			}
		}

		problemField?.addEventListener('input', updateProblemCounter);
		updateProblemCounter();

		// Fun little completion meter — one "step" per required field/group, filling as each is
		// satisfied. Purely cosmetic, doesn't gate submission (native validation already does that).
		const progressFill = document.getElementById('cf-progress-fill');
		const progressTrack = document.getElementById('cf-progress');

		function updateProgress() {
			if (!form) return;
			const requiredEls = Array.from(form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[required]'));
			const seenRadioGroups = new Set<string>();
			let total = 0;
			let satisfied = 0;

			for (const el of requiredEls) {
				if (el.closest('[hidden]')) continue;

				if (el instanceof HTMLInputElement && el.type === 'radio') {
					if (seenRadioGroups.has(el.name)) continue;
					seenRadioGroups.add(el.name);
					total++;
					if (form.querySelector(`input[name="${el.name}"]:checked`)) satisfied++;
					continue;
				}

				total++;
				if (el instanceof HTMLInputElement && el.type === 'checkbox') {
					if (el.checked) satisfied++;
				} else if (el.value.trim()) {
					satisfied++;
				}
			}

			const pct = total ? Math.round((satisfied / total) * 100) : 0;
			if (progressFill) progressFill.style.width = `${pct}%`;
			if (progressTrack) progressTrack.setAttribute('aria-valuenow', String(pct));
		}

		form.addEventListener('input', updateProgress);
		form.addEventListener('change', updateProgress);
		updateProgress();

		const DRAFT_KEY = 'cf-draft';

		function saveDraft() {
			const locationChecked = form!.querySelector<HTMLInputElement>('input[name="location"]:checked');
			const transportChecked = form!.querySelector<HTMLInputElement>('input[name="transport"]:checked');
			localStorage.setItem(DRAFT_KEY, JSON.stringify({
				name: (document.getElementById('cf-name') as HTMLInputElement | null)?.value ?? '',
				contact: (document.getElementById('cf-contact') as HTMLInputElement | null)?.value ?? '',
				problem: (document.getElementById('cf-problem') as HTMLTextAreaElement | null)?.value ?? '',
				device: (document.getElementById('cf-device') as HTMLSelectElement | null)?.value ?? '',
				location: locationChecked?.dataset.value ?? '',
				transport: transportChecked?.value ?? '',
				locationOther: (document.getElementById('cf-location-other') as HTMLInputElement | null)?.value ?? '',
			}));
		}

		function restoreDraft() {
			const raw = localStorage.getItem(DRAFT_KEY);
			if (!raw) return;
			try {
				const d = JSON.parse(raw);
				const setVal = (id: string, val: string) => {
					const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
					if (el && val) el.value = val;
				};
				setVal('cf-name', d.name);
				setVal('cf-contact', d.contact);
				setVal('cf-problem', d.problem);
				setVal('cf-device', d.device);
				if (d.location) {
					const r = form!.querySelector<HTMLInputElement>(`input[name="location"][data-value="${d.location}"]`);
					if (r) r.checked = true;
				}
				if (d.transport) {
					const r = form!.querySelector<HTMLInputElement>(`input[name="transport"][value="${d.transport}"]`);
					if (r) r.checked = true;
				}
				setVal('cf-location-other', d.locationOther);
				syncLocationOther();
				updateProblemCounter();
				updateProgress();
			} catch {}
		}

		restoreDraft();
		form.addEventListener('input', saveDraft);
		form.addEventListener('change', saveDraft);

		// Warn before navigating away if anything has been typed — refreshing is fine since the
		// draft is saved to localStorage, but clicking a nav link would lose the current session state.
		window.addEventListener('beforeunload', (e) => {
			const hasInput = ['cf-name', 'cf-contact', 'cf-problem'].some(
				(id) => !!(document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null)?.value.trim()
			);
			if (hasInput) e.preventDefault();
		});

		const status = form.querySelector<HTMLParagraphElement>('.contact-form__status');
		const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
		const webhookUrl = import.meta.env.PUBLIC_DISCORD_WEBHOOK_URL as string | undefined;

		const messages = lang === 'en'
			? {
					submitting: 'Sending…',
					submit: 'Send request',
					success: "Thanks — we've received your request and will get back to you shortly. If it's urgent, just call us.",
					error: 'Something went wrong sending the form. Please call or email us directly instead.',
					testMode: "Contact form is in test mode during local development — submissions aren't sent anywhere yet.",
					notProvided: 'not provided',
					photoTooLarge: "That photo is over 8 MB — please pick a smaller one or leave it out.",
					tooSoon: "You've just sent a request — please wait a bit before sending another.",
					invalidContact: 'Please enter a valid Polish phone number or email address.',
				}
			: {
					submitting: 'Wysyłanie…',
					submit: 'Wyślij zgłoszenie',
					success: 'Dziękujemy — otrzymaliśmy Twoje zgłoszenie i wkrótce się odezwiemy. Jeśli sprawa jest pilna, po prostu zadzwoń.',
					error: 'Coś poszło nie tak przy wysyłce formularza. Zadzwoń lub napisz do nas bezpośrednio.',
					testMode: 'Formularz kontaktowy działa w trybie testowym podczas lokalnego developmentu — zgłoszenia nie są jeszcze nigdzie wysyłane.',
					notProvided: 'nie podano',
					photoTooLarge: 'To zdjęcie waży ponad 8 MB — wybierz mniejsze albo pomiń załącznik.',
					tooSoon: 'Właśnie wysłałeś/aś zgłoszenie — odczekaj chwilę przed kolejnym.',
					invalidContact: 'Podaj prawidłowy polski numer telefonu albo adres e-mail.',
				};

		// Accepts a Polish phone number in pretty much any grouping (500 000 000, 500-000-000,
		// 500000000, +48 500 000 000, 0048500000000, ...) or an email address, and normalizes
		// the phone case to a single consistent "+48 XXX XXX XXX" format before it's sent — so
		// whoever reads the Discord message can just tap-to-call it, however the visitor typed it.
		function normalizeContact(raw: string): string | null {
			const value = raw.trim();
			if (!value) return null;

			if (value.includes('@')) {
				// Deliberately loose — full RFC 5322 validation isn't worth it here, this just
				// catches obvious typos ("jan@" or "@x.com") rather than gatekeeping edge cases.
				const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
				return emailPattern.test(value) ? value : null;
			}

			let digits = value.replace(/[\s-()]/g, '');
			if (digits.startsWith('+48')) digits = digits.slice(3);
			else if (digits.startsWith('0048')) digits = digits.slice(4);
			else if (digits.startsWith('48') && digits.length === 11) digits = digits.slice(2);

			if (!/^\d{9}$/.test(digits)) return null;
			return `+48 ${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
		}

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!form.checkValidity()) {
				form.reportValidity();
				return;
			}

			// Honeypot: if filled, a bot did it — silently drop without revealing anything.
			const honeypot = form.querySelector<HTMLInputElement>('#cf-website');
			if (honeypot && honeypot.value) {
				return;
			}

			// Weak but cheap anti-spam: a per-browser cooldown between submissions. Doesn't stop a
			// determined bot (localStorage is trivial to clear/spoof), but it does stop the common
			// case of someone mashing the button, and costs nothing since there's no backend to do
			// real rate limiting on a static site — Discord's own webhook rate limit is the backstop.
			const COOLDOWN_MS = 30_000;
			const lastSubmit = Number(localStorage.getItem('cf-last-submit') ?? 0);
			if (Date.now() - lastSubmit < COOLDOWN_MS) {
				if (status) {
					status.textContent = messages.tooSoon;
					status.dataset.state = 'error';
				}
				return;
			}

			// Validate + normalize the phone-or-email field so however someone types their number
			// (spaces, dashes, +48, a leading 0, none of the above), the business always sees one
			// consistent, tappable format — and obvious typos get caught before they ever reach Discord.
			const contactField = form.querySelector<HTMLInputElement>('#cf-contact');
			const contactErrorEl = document.getElementById('cf-contact-error');
			const normalizedContact = contactField ? normalizeContact(contactField.value) : null;
			if (!normalizedContact) {
				if (contactErrorEl) contactErrorEl.textContent = messages.invalidContact;
				contactField?.setAttribute('aria-invalid', 'true');
				contactField?.focus();
				return;
			}
			if (contactErrorEl) contactErrorEl.textContent = '';
			contactField?.removeAttribute('aria-invalid');

			// Discord webhooks reject attachments over 8 MB (25 MB only on boosted servers) — check
			// client-side first so a large photo fails fast with a clear message instead of a
			// confusing network error after the user has already waited.
			const photoInputEl = form.querySelector<HTMLInputElement>('#cf-photo');
			const photoFile = photoInputEl?.files?.[0];
			if (photoFile && photoFile.size > 8 * 1024 * 1024) {
				if (status) {
					status.textContent = messages.photoTooLarge;
					status.dataset.state = 'error';
				}
				return;
			}

			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = messages.submitting;
			}

			// Stage 1: no real webhook exists yet (created in Stage 2 once Discord is set up).
			// Handle that gracefully instead of throwing a confusing fetch error against an empty URL.
			if (!webhookUrl) {
				if (status) {
					status.textContent = messages.testMode;
					status.dataset.state = 'success';
				}
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = messages.submit;
				}
				return;
			}

			const name = (form.querySelector<HTMLInputElement>('#cf-name')?.value ?? '').trim();
			const contact = normalizedContact;
			const locationChecked = form.querySelector<HTMLInputElement>('input[name="location"]:checked');
			const locationOther = (document.getElementById('cf-location-other') as HTMLInputElement | null)?.value.trim();
			const location = locationChecked?.dataset.value === 'okolica' && locationOther
				? `${locationChecked.value} (${locationOther})`
				: (locationChecked?.value ?? '');
			const device = form.querySelector<HTMLSelectElement>('#cf-device')?.value ?? '';
			const problem = (form.querySelector<HTMLTextAreaElement>('#cf-problem')?.value ?? '').trim();
			const transport = form.querySelector<HTMLInputElement>('input[name="transport"]:checked')?.value ?? '';
			const photo = photoFile;

			// multipart/form-data (not JSON) so a photo attachment can ride along — Discord webhooks
			// accept file uploads this way via payload_json + file fields.
			const body = new FormData();
			body.append(
				'payload_json',
				JSON.stringify({
					content: `**Nowe zgłoszenie — ${name}**\nKontakt: ${contact}\nLokalizacja: ${location || messages.notProvided}\nUrządzenie: ${device || messages.notProvided}\nTransport: ${transport || messages.notProvided}\nProblem: ${problem || messages.notProvided}`,
					// Submitted text reaches Discord as raw message content — without this, a crafted
					// "@everyone" or "@here" in any field would actually ping the whole server.
					allowed_mentions: { parse: [] },
				})
			);
			if (photo) {
				body.append('files[0]', photo, photo.name);
			}

			try {
				localStorage.setItem('cf-last-submit', String(Date.now()));
				const res = await fetch(webhookUrl, { method: 'POST', body });
				if (!res.ok) throw new Error(`Webhook responded ${res.status}`);
				localStorage.removeItem(DRAFT_KEY);
				form.hidden = true;
				if (status) {
					status.textContent = messages.success;
					status.dataset.state = 'success';
				}
			} catch {
				if (status) {
					status.textContent = messages.error;
					status.dataset.state = 'error';
				}
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = messages.submit;
				}
			}
		});
	}
</script>
