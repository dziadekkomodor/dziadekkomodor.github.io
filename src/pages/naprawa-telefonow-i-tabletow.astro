---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBlock from '../components/TrustBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { services } from '../data/services';
import { site } from '../data/site';
import { localePath } from '../data/nav';
import heroPhoto from '../assets/photos/hero-phone.png';

const lang = "pl" as const;
const svc = services.find((s) => s.slug === "naprawa-telefonow-i-tabletow")!;
// Pre-select "Telefon" on the contact form — more common than tablets on this page.
const contactHref = `${localePath(lang, "kontakt")}?device=phone`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: svc.serviceType[lang],
    provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
    areaServed: site.serviceAreaTowns.map((name) => ({ "@type": "City", name })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Czy można naprawić telefon po zalaniu?",
        acceptedAnswer: { "@type": "Answer", text: "Tak, pod warunkiem że przyniesiesz sprzęt jak najszybciej — im szybciej, tym większa szansa na uratowanie telefonu. Czyszczenie po zalaniu kosztuje 150–280 zł." },
      },
      {
        "@type": "Question",
        name: "Czy wymieniacie tylko szybkę bez wymiany całego wyświetlacza?",
        acceptedAnswer: { "@type": "Answer", text: "Tak, w wybranych modelach możliwa jest wymiana samej szybki bez wymiany matrycy, od 250 zł. Czy jest to możliwe w Twoim telefonie, potwierdzimy po bezpłatnej diagnozie." },
      },
      {
        "@type": "Question",
        name: "Czy naprawiacie telefony w Bydgoszczy i Pile?",
        acceptedAnswer: { "@type": "Answer", text: "Tak. Obsługujemy klientów z Piły, Bydgoszczy i okolic. Możliwy jest odbiór telefonu — koszt paliwa w obie strony plus 12 zł, dostępność potwierdzamy po kontakcie." },
      },
      {
        "@type": "Question",
        name: "Ile kosztuje naprawa portu ładowania w telefonie?",
        acceptedAnswer: { "@type": "Answer", text: "Koszt naprawy portu ładowania zależy od modelu telefonu i zakresu uszkodzenia. Dokładną kwotę podajemy zawsze po bezpłatnej diagnozie wstępnej." },
      },
    ],
  },
];
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Naprawa telefonów i tabletów — Piła, Bydgoszcz i okolice"
		headline="Pęknięty ekran to nie koniec telefonu."
		subhead="Wymiana szybki, wyświetlacza i baterii, naprawa portu ładowania — z bezpłatną diagnozą i jasną wyceną na start."
		ctaLabel="Darmowa wycena"
		ctaHref={contactHref}
		photoCaptionPl="Rozłożony smartfon podczas naprawy — płyta główna i rama obudowy"
		photoCaptionEn="Disassembled smartphone during repair — motherboard and chassis frame"
		photo={heroPhoto}
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>Co najczęściej naprawiamy</h2>
		<ul>
			<li>Wymiana szybki — pęknięte lub porysowane szkło ochronne ekranu.</li>
			<li>Wymiana wyświetlacza — uszkodzony obraz, martwe piksele, brak dotyku.</li>
			<li>Wymiana baterii — telefon szybko się rozładowuje albo się wyłącza.</li>
			<li>Naprawa portu ładowania — telefon nie ładuje się lub trzeba trzymać kabel pod kątem.</li>
			<li>Ratowanie danych i czyszczenie po zalaniu.</li>
			<li>Naprawy tabletów — te same usterki, ten sam proces.</li>
		</ul>
		<p class="services-list__note">
			Ceny wymiany szybki, wyświetlacza i baterii znajdziesz na <a href={localePath(lang, "cennik")}>stronie z cennikiem</a> — dokładna kwota zależy od modelu urządzenia i jest potwierdzana po bezpłatnej diagnozie.
		</p>
	</section>

	<TrustBlock lang={lang} heading="Wiemy, o co się martwisz" />

	<ProcessSteps lang={lang} heading="Jak wygląda naprawa krok po kroku" />

	<CtaBanner
		heading="Przynieś telefon albo wyślij zapytanie"
		body={`Bezpłatna diagnoza, wycena na piśmie, ${site.warrantyMonths} miesiące gwarancji na naprawę.`}
		ctaLabel="Darmowa wycena"
		ctaHref={contactHref}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}

	.services-list__note {
		margin-top: var(--space-4);
		color: var(--color-ink-soft);
		max-width: 62ch;
	}
</style>
