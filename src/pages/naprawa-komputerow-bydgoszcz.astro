---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBlock from '../components/TrustBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { services } from '../data/services';
import { site } from '../data/site';
import { localePath } from '../data/nav';

const lang = "pl" as const;
const svc = services.find((s) => s.slug === "naprawa-komputerow-bydgoszcz")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: [{ "@type": "City", name: "Piła" }, { "@type": "City", name: "Bydgoszcz" }],
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Naprawa komputerów — Bydgoszcz"
		headline="Naprawa komputerów w Bydgoszczy, bez ukrytych kosztów."
		subhead="Ten sam transparentny proces co w Pile — bezpłatna diagnoza, jasna wycena, naprawa dopiero po Twojej akceptacji."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Zdjęcie naprawianego komputera stacjonarnego — do dodania"
		photoCaptionEn="Photo of a desktop computer being repaired — to be added"
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>Co najczęściej naprawiamy</h2>
		<ul>
			<li>Czyszczenie wnętrza obudowy i wymiana pasty termoprzewodzącej.</li>
			<li>Wymiana dysku HDD/SSD i migracja systemu bez utraty danych.</li>
			<li>Naprawa układu zasilania płyty głównej i lutowanie BGA.</li>
			<li>Diagnostyka i naprawa BIOS.</li>
			<li>Instalacja i konfiguracja systemu operacyjnego.</li>
			<li>Odzyskiwanie danych — podstawowe na miejscu, złożone przypadki we współpracy z zewnętrznym laboratorium.</li>
		</ul>
	</section>

	<TrustBlock lang={lang} heading="Wiemy, o co się martwisz" />

	<ProcessSteps lang={lang} heading="Jak wygląda naprawa krok po kroku" />

	<CtaBanner
		heading="Zapytaj o wycenę naprawy komputera"
		body="Bezpłatna diagnoza, wycena na piśmie, 5 miesięcy gwarancji na naprawę."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}
</style>
