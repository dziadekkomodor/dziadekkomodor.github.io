---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBlock from '../components/TrustBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { services } from '../data/services';
import { site } from '../data/site';
import { localePath } from '../data/nav';
import heroPhoto from '../assets/photos/hero-laptop.jpg';

const lang = "pl" as const;
const svc = services.find((s) => s.slug === "naprawa-laptopow-pila")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: [{ "@type": "City", name: "Piła" }, { "@type": "City", name: "Bydgoszcz" }],
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Naprawa laptopów — Piła"
		headline="Twój laptop znowu będzie działał, jak powinien."
		subhead="Czyszczenie, wymiana dysku i matrycy, naprawy płyty głównej — z bezpłatną diagnozą i jasną wyceną na start."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Zdjęcie naprawianego laptopa — do dodania"
		photoCaptionEn="Photo of a laptop being repaired — to be added"
		photo={heroPhoto}
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>Co najczęściej naprawiamy</h2>
		<ul>
			<li>Czyszczenie z kurzu i wymiana pasty termoprzewodzącej — laptop się przegrzewa lub głośno pracuje.</li>
			<li>Wymiana dysku HDD/SSD — poprawa szybkości działania lub awaria dysku.</li>
			<li>Wymiana matrycy — pęknięty lub uszkodzony ekran.</li>
			<li>Naprawa zawiasów i obudowy — luźna lub pęknięta obudowa.</li>
			<li>Instalacja systemu operacyjnego od podstaw.</li>
			<li>Czyszczenie po zalaniu — im szybciej przyniesiesz sprzęt, tym większa szansa na pełną naprawę.</li>
		</ul>
	</section>

	<TrustBlock lang={lang} heading="Wiemy, o co się martwisz" />

	<ProcessSteps lang={lang} heading="Jak wygląda naprawa krok po kroku" />

	<CtaBanner
		heading="Przynieś laptop albo wyślij zapytanie"
		body="Bezpłatna diagnoza, wycena na piśmie, 5 miesięcy gwarancji na naprawę."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}
</style>
