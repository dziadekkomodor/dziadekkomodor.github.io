---
import PageLayout from '../layouts/PageLayout.astro';
import PlaceholderReviews from '../components/PlaceholderReviews.astro';
import Reviews from '../components/Reviews.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { site } from '../data/site';
import reviewsData from '../data/reviews.json';

const lang = "pl" as const;
const title = "Opinie";
const description = "Opinie klientów o Dziadku Komodorze — serwisie komputerowym w Pile, Bydgoszczy i okolicach.";
const hasReviews = reviewsData.reviews.length > 0;
---

<PageLayout lang={lang} slug="opinie" title={title} description={description}>
	<section class="container page-hero" data-animate="reveal">
		<h1>Opinie</h1>
		<p class="page-hero__lead">
			Nie publikujemy niczego, czego nie da się zweryfikować — tylko prawdziwe opinie od
			prawdziwych klientów.
		</p>
	</section>

	<section class="container" data-animate="reveal">
		{hasReviews
			? <Reviews reviews={reviewsData.reviews} lang={lang} />
			: <PlaceholderReviews lang={lang} />
		}
	</section>

	<CtaBanner
		heading={hasReviews ? "Zostaw nam opinię" : "Bądź jednym z pierwszych klientów"}
		body="Pomóż nam zbudować listę opinii — zostaw swoją po naprawie."
		ctaLabel="Napisz opinię na Google"
		ctaHref={site.socials.googleReview}
	/>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}
</style>
