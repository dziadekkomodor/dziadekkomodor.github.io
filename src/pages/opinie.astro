---
import PageLayout from '../layouts/PageLayout.astro';
import PlaceholderReviews from '../components/PlaceholderReviews.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { localePath } from '../data/nav';

const lang = "pl" as const;
const title = "Opinie";
const description = "Opinie klientów o Dziadku Komodorze — serwisie komputerowym w Pile i Bydgoszczy.";
---

<PageLayout lang={lang} slug="opinie" title={title} description={description}>
	<section class="container page-hero" data-animate="reveal">
		<h1>Opinie</h1>
		<p class="page-hero__lead">
			Nie publikujemy niczego, czego nie da się zweryfikować — tylko prawdziwe opinie od
			prawdziwych klientów.
		</p>
	</section>

	<section class="container">
		<PlaceholderReviews lang={lang} />
	</section>

	<CtaBanner
		heading="Bądź jednym z pierwszych klientów"
		body="Pomóż nam zbudować listę opinii — zostaw swoją po naprawie."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}
</style>
