---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { Image } from 'astro:assets';
import { services } from '../../data/services';
import { site } from '../../data/site';
import { localePath } from '../../data/nav';
import heroPhoto from '../../assets/photos/hero-gaming-build.png';
import portfolioPhoto1 from '../../assets/photos/gaming-portfolio-2.png';
import portfolioPhoto2 from '../../assets/photos/gaming-portfolio-1.jpg';
import portfolioPhoto3 from '../../assets/photos/gaming-portfolio-3.png';

const lang = "en" as const;
const svc = services.find((s) => s.slug === "komputery-gamingowe-bydgoszcz")!;
const contactHref = `${localePath(lang, "kontakt")}?device=gaming-pc`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: [{ "@type": "City", name: "Piła" }, { "@type": "City", name: "Bydgoszcz" }],
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd} theme="gaming">
	<Hero
		lang={lang}
		eyebrow="Gaming PCs — Bydgoszcz & Piła"
		headline="The boutique builder Bydgoszcz hasn't had yet."
		subhead="Custom builds, GPU and cooling upgrades, component-level repairs — with real component-level understanding, not just parts-swapping."
		ctaLabel="Get a build or repair quote"
		ctaHref={contactHref}
		photoCaptionPl="Zdjęcie zbudowanego PC gamingowego — do dodania"
		photoCaptionEn="Photo of a completed gaming PC build — to be added"
		photo={heroPhoto}
	/>

	<section class="container gaming-specs" data-animate="reveal">
		<h2>What we do</h2>
		<div class="gaming-specs__grid">
			<div>
				<h3>Custom builds</h3>
				<p>Component selection built around your budget and the specific games you play — advice included, not just a parts list.</p>
			</div>
			<div>
				<h3>GPU & cooling upgrades</h3>
				<p>Graphics card swaps, moving to liquid cooling, airflow optimization.</p>
			</div>
			<div>
				<h3>Component-level repairs</h3>
				<p>BGA soldering, motherboard power-circuit repair, BIOS diagnostics.</p>
			</div>
			<div>
				<h3>Gaming laptop service</h3>
				<p>Cleaning and thermal paste replacement for laptops that heat up under load.</p>
			</div>
		</div>
	</section>

	<section class="container gaming-portfolio" data-animate="reveal">
		<h2>Build portfolio</h2>
		<p>A few of our recent builds — more will show up here as we document further projects.</p>
		<div class="gaming-portfolio__gallery">
			<Image src={portfolioPhoto1} alt="A white-case build with liquid cooling and RGB lighting" width={900} height={1000} format="webp" class="gaming-portfolio__photo gaming-portfolio__photo--featured" />
			<Image src={portfolioPhoto2} alt="A completed gaming PC build with a GeForce RTX card" width={800} height={520} format="webp" class="gaming-portfolio__photo" />
			<Image src={portfolioPhoto3} alt="A configured gaming laptop with a performance monitor open" width={800} height={520} format="webp" class="gaming-portfolio__photo" />
		</div>
	</section>

	<ProcessSteps lang={lang} heading="How a job works, step by step" />

	<CtaBanner
		heading="Got a build in mind, or a hardware problem?"
		body="Tell us what parts you're after or what's acting up — we'll get back to you with specifics."
		ctaLabel="Get a build or repair quote"
		ctaHref={contactHref}
	/>
</PageLayout>

<style>
	.gaming-specs,
	.gaming-portfolio {
		padding-block: var(--space-7);
	}

	.gaming-specs__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-5);
		margin-top: var(--space-5);
	}

	.gaming-specs__grid h3 {
		color: var(--color-accent);
		font-size: var(--text-lg);
		margin-bottom: var(--space-2);
	}

	.gaming-specs__grid p {
		color: var(--color-ink-soft);
		margin: 0;
	}

	.gaming-portfolio p {
		color: var(--color-ink-soft);
		margin-bottom: var(--space-4);
	}

	.gaming-portfolio__gallery {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
	}

	.gaming-portfolio__photo {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: var(--radius-soft);
	}

	.gaming-portfolio__photo--featured {
		aspect-ratio: 4 / 3;
	}

	@media (min-width: 800px) {
		.gaming-specs__grid {
			grid-template-columns: repeat(4, 1fr);
		}

		.gaming-portfolio__gallery {
			grid-template-columns: 1.1fr 1fr;
			grid-template-rows: repeat(2, 1fr);
		}

		.gaming-portfolio__photo--featured {
			grid-row: 1 / 3;
			height: 100%;
			aspect-ratio: auto;
		}
	}
</style>
