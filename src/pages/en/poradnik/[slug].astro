---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import { localePath } from '../../../data/nav';

const lang = "en" as const;

export async function getStaticPaths() {
  const posts = await getCollection('poradnik', (entry) => entry.id.startsWith('en/'));
  return posts.map((post) => ({
    params: { slug: post.id.slice('en/'.length) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const baseSlug = post.id.slice('en/'.length);
---

<PageLayout lang={lang} slug={`poradnik/${baseSlug}`} title={post.data.title} description={post.data.description}>
	<article class="container post" data-animate="reveal">
		<h1>{post.data.title}</h1>
		<div class="post__content">
			<Content />
		</div>
	</article>

	<CtaBanner
		heading="Does this sound familiar?"
		body="Book a free diagnosis — we'll check what's actually wrong."
		ctaLabel="Free quote"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.post {
		padding-block: var(--space-6) var(--space-7);
		max-width: 68ch;
	}

	.post__content {
		font-size: var(--text-lg);
		line-height: var(--leading-relaxed);
	}

	.post__content :global(h2) {
		font-size: var(--text-xl);
		margin-top: var(--space-6);
	}

	.post__content :global(a) {
		color: var(--color-accent);
	}
</style>
