---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBlock from '../../components/TrustBlock.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';
import { localePath } from '../../data/nav';

const lang = "en" as const;
const svc = services.find((s) => s.slug === "naprawa-laptopow-pila")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: [{ "@type": "City", name: "Piła" }, { "@type": "City", name: "Bydgoszcz" }],
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Laptop repair — Piła"
		headline="Your laptop, working the way it should again."
		subhead="Cleaning, drive and screen replacement, motherboard repairs — with a free diagnosis and a clear quote to start."
		ctaLabel="Free quote"
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Zdjęcie naprawianego laptopa — do dodania"
		photoCaptionEn="Photo of a laptop being repaired — to be added"
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>What we repair most often</h2>
		<ul>
			<li>Dust cleaning and thermal paste replacement — your laptop overheats or runs loudly.</li>
			<li>HDD/SSD replacement — faster performance or a failing drive.</li>
			<li>Screen replacement — a cracked or damaged display.</li>
			<li>Hinge and case repair — a loose or cracked chassis.</li>
			<li>Clean operating system installs.</li>
			<li>Liquid-damage cleaning — the sooner you bring it in, the better the odds of a full recovery.</li>
		</ul>
	</section>

	<TrustBlock lang={lang} heading="We know what you're worried about" />

	<ProcessSteps lang={lang} heading="How a repair works, step by step" />

	<CtaBanner
		heading="Drop off your laptop or send us a request"
		body="Free diagnosis, a written quote, a 5-month warranty on the repair."
		ctaLabel="Free quote"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}
</style>
