---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBlock from '../../components/TrustBlock.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';
import { localePath } from '../../data/nav';
import heroPhoto from '../../assets/photos/hero-business.jpg';

const lang = "en" as const;
const svc = services.find((s) => s.slug === "uslugi-it-dla-firm")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: site.serviceAreaTowns.map((name) => ({ "@type": "City", name })),
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="IT services for businesses — Piła & Bydgoszcz"
		headline="IT support your business can actually rely on."
		subhead="Break/fix service, fast response times, and post-lease hardware — so a hardware failure doesn't stop your team from working."
		ctaLabel="Ask about our services"
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Albert i Mikołaj — współzałożyciele Dziadka Komodora"
		photoCaptionEn="Albert and Mikołaj — co-founders of Dziadek Komodor"
		photo={heroPhoto}
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>How we can help your business</h2>
		<ul>
			<li>Break/fix service — fast repair of office hardware and workstation faults.</li>
			<li>On-site support at your business, when that's more convenient than shipping hardware.</li>
			<li>Sourcing and prepping post-lease hardware — a cheaper alternative to buying new.</li>
			<li>Data migration and setup of new workstations.</li>
			<li>Regular hardware maintenance to reduce the number of failures.</li>
		</ul>
		<p class="services-list__note">
			We support small businesses and micro-firms in Piła, Bydgoszcz, and the surrounding area —
			we understand that downtime for your hardware means downtime for your work.
		</p>
	</section>

	<TrustBlock lang={lang} heading="We know what you're worried about" />

	<ProcessSteps lang={lang} heading="How working with us works, step by step" />

	<CtaBanner
		heading="Let's talk about IT support for your business"
		body="We'll reply quickly and scope the service to what you actually need."
		ctaLabel="Ask about our services"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}

	.services-list__note {
		margin-top: var(--space-4);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}
</style>
