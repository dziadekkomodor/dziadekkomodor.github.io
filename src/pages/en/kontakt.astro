---
import PageLayout from '../../layouts/PageLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { site } from '../../data/site';

const lang = "en" as const;
const title = "Contact";
const description = "Get in touch with Dziadek Komodor — phone, request form, opening hours. We serve Piła, Bydgoszcz, and the surrounding area.";
---

<PageLayout lang={lang} slug="kontakt" title={title} description={description}>
	<section class="container page-hero" data-animate="reveal">
		<h1>Contact</h1>
		<p class="page-hero__lead">
			Call, message, or fill out the form below — we reply quickly.
		</p>
	</section>

	<section class="container kontakt-grid">
		<div class="kontakt-info" data-animate="reveal">
			<h2>Contact details</h2>
			<dl>
				<div>
					<dt>Phone</dt>
					<dd><a href={site.phone.href}>{site.phone.display}</a></dd>
				</div>
				<div>
					<dt>Email</dt>
					<dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
				</div>
				<div>
					<dt>Service area</dt>
					<dd>{site.serviceAreasNote[lang]}</dd>
				</div>
				<div>
					<dt>Hours</dt>
					<dd>{site.hoursDisplay[lang]}</dd>
				</div>
			</dl>
			<div class="kontakt-area-note">
				<svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M12 21s-7-6.5-7-11.5A7 7 0 0119 9.5C19 14.5 12 21 12 21z" />
					<circle cx="12" cy="9.5" r="2.5" />
				</svg>
				<p>
					We operate from Wyrzysk as a service-area business without a walk-in address. Pickup,
					courier drop-off, or an on-site visit can be arranged by phone.
				</p>
			</div>
			<div class="kontakt-towns">
				<p class="kontakt-towns__label">Towns we serve</p>
				<p class="kontakt-towns__list">{site.serviceAreaTowns.join(", ")} and other nearby towns. Don't see your town? Get in touch anyway — if we can reach you or accept a courier, we'll be glad to help.</p>
			</div>
		</div>

		<div data-animate="reveal">
			<h2>Request form</h2>
			<ContactForm lang={lang} />
		</div>
	</section>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}

	.kontakt-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-7);
		padding-block: var(--space-6) var(--space-8);
	}

	.kontakt-info dl {
		display: grid;
		gap: var(--space-4);
		margin: var(--space-4) 0 var(--space-5);
	}

	.kontakt-info dt {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-ink-soft);
	}

	.kontakt-info dd {
		margin: 0;
		font-family: var(--font-headline);
		font-weight: var(--weight-headline-bold);
		font-size: var(--text-lg);
	}

	.kontakt-info dd a {
		color: var(--color-ink);
		text-decoration: none;
	}

	.kontakt-area-note {
		display: flex;
		gap: var(--space-3);
		align-items: flex-start;
		padding: var(--space-4);
		background: var(--color-bg-raised);
		border-radius: var(--radius-soft);
		color: var(--color-ink-soft);
	}

	.kontakt-area-note svg {
		flex-shrink: 0;
		color: var(--color-accent);
	}

	.kontakt-area-note p {
		margin: 0;
		font-size: var(--text-sm);
	}

	.kontakt-towns {
		margin-top: var(--space-4);
		font-size: var(--text-sm);
		color: var(--color-ink-soft);
	}

	.kontakt-towns__label {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-ink-soft);
		margin-bottom: var(--space-1);
	}

	.kontakt-towns__list {
		margin: 0;
		line-height: 1.7;
	}

	@media (min-width: 900px) {
		.kontakt-grid {
			grid-template-columns: 1fr 1.3fr;
		}
	}
</style>
