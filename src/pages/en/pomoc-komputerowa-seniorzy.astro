---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';
import heroPhoto from '../../assets/photos/hero-senior.jpg';

const lang = "en" as const;
const svc = services.find((s) => s.slug === "pomoc-komputerowa-seniorzy")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: site.serviceAreaTowns.map((name) => ({ "@type": "City", name })),
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd} density="comfortable">
	<Hero
		lang={lang}
		eyebrow="Computer help for seniors"
		headline="Patient help, without the jargon."
		subhead="We explain things in plain language, without rushing. We can visit you at home if that's easier."
		ctaLabel="Call us"
		ctaHref={site.phone.href}
		photoCaptionPl="Zdjęcie: pomoc komputerowa u seniora w domu — do dodania"
		photoCaptionEn="Photo: helping a senior with a computer at home — to be added"
		photo={heroPhoto}
	/>

	<section class="container senior-help" data-animate="reveal">
		<h2>What we can help with</h2>
		<ul>
			<li>A slow computer or phone.</li>
			<li>Problems with the internet, email, or Skype/WhatsApp.</li>
			<li>Viruses, strange pop-ups, or ads that won't go away.</li>
			<li>Setting up new hardware — step by step, for as long as it takes to be clear.</li>
			<li>Lost photos or documents — we'll help you get them back.</li>
		</ul>
		<div class="senior-help__promise">
			<h3>Our promise</h3>
			<p>We explain everything in plain language — no jargon, no rushing. You can just call and ask
			a question before bringing anything in. If you'd prefer we come to you, just say so — we
			serve Piła, Bydgoszcz, and the surrounding towns.</p>
		</div>
	</section>

	<ProcessSteps lang={lang} heading="How our help works, step by step" />

	<CtaBanner
		heading="Call us — we'll talk it through and advise what's next"
		body="You don't need to bring or send anything just to ask."
		ctaLabel="Call now"
		ctaHref={site.phone.href}
	/>
</PageLayout>

<style>
	.senior-help {
		padding-block: var(--space-7);
	}

	.senior-help ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 62ch;
	}

	.senior-help li {
		font-size: var(--text-lg);
	}

	.senior-help__promise {
		margin-top: var(--space-6);
		padding: var(--space-5);
		background: var(--color-bg-raised);
		border-radius: var(--radius-soft);
		max-width: 62ch;
	}

	.senior-help__promise h3 {
		margin-bottom: var(--space-2);
	}

	.senior-help__promise p {
		margin: 0;
		color: var(--color-ink-soft);
	}
</style>
