---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBlock from '../../components/TrustBlock.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';
import { localePath } from '../../data/nav';

const lang = "en" as const;
const svc = services.find((s) => s.slug === "naprawa-telefonow-i-tabletow")!;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: [{ "@type": "City", name: "Piła" }, { "@type": "City", name: "Bydgoszcz" }],
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Phone & tablet repair — Piła and Bydgoszcz"
		headline="A cracked screen isn't the end of your phone."
		subhead="Glass, display, and battery replacement, charging port repair — with a free diagnosis and a clear quote to start."
		ctaLabel="Free quote"
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Zdjęcie naprawianego telefonu — do dodania"
		photoCaptionEn="Photo of a phone being repaired — to be added"
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>What we repair most often</h2>
		<ul>
			<li>Glass replacement — cracked or scratched screen protector glass.</li>
			<li>Display replacement — damaged image, dead pixels, unresponsive touch.</li>
			<li>Battery replacement — the phone drains fast or shuts itself off.</li>
			<li>Charging port repair — won't charge, or you have to hold the cable at an angle.</li>
			<li>Data rescue and cleaning after liquid damage.</li>
			<li>Tablet repairs — the same faults, the same process.</li>
		</ul>
		<p class="services-list__note">
			Glass, display, and battery replacement prices are on the <a href={localePath(lang, "cennik")}>pricing page</a> — the exact amount depends on the device model and is confirmed after a free diagnosis.
		</p>
	</section>

	<TrustBlock lang={lang} heading="We know what you're worried about" />

	<ProcessSteps lang={lang} heading="How a repair works, step by step" />

	<CtaBanner
		heading="Drop off your phone or send us a request"
		body="Free diagnosis, a written quote, a 5-month warranty on the repair."
		ctaLabel="Free quote"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}

	.services-list__note {
		margin-top: var(--space-4);
		color: var(--color-ink-soft);
		max-width: 62ch;
	}
</style>
