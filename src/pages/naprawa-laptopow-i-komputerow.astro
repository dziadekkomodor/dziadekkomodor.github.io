---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBlock from '../components/TrustBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { services } from '../data/services';
import { site } from '../data/site';
import { localePath } from '../data/nav';
import heroPhoto from '../assets/photos/hero-laptop.jpg';

const lang = "pl" as const;
const svc = services.find((s) => s.slug === "naprawa-laptopow-i-komputerow")!;
// Pre-select "Laptop" on the contact form — the more common of the two device types this page covers.
const contactHref = `${localePath(lang, "kontakt")}?device=laptop`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: svc.serviceType[lang],
  provider: { "@type": "ProfessionalService", "@id": `${site.url}/#firma` },
  areaServed: site.serviceAreaTowns.map((name) => ({ "@type": "City", name })),
};
---

<PageLayout lang={lang} slug={svc.slug} title={svc.title[lang]} description={svc.metaDescription[lang]} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow="Naprawa laptopów i komputerów — Piła, Bydgoszcz i okolice"
		headline="Twój sprzęt znowu będzie działał, jak powinien."
		subhead="Laptopy i komputery stacjonarne — obsługujemy Piłę, Bydgoszcz i okolicę jednakowo. Bezpłatna diagnoza i jasna wycena na start."
		ctaLabel="Darmowa wycena"
		ctaHref={contactHref}
		photoCaptionPl="Zdjęcie naprawianego sprzętu — do dodania"
		photoCaptionEn="Photo of a device being repaired — to be added"
		photo={heroPhoto}
	/>

	<section class="container services-list" data-animate="reveal">
		<h2>Co najczęściej naprawiamy</h2>
		<p class="services-list__note">Ten sam zakres usług i ten sam transparentny proces — niezależnie od tego, czy przyjeżdżasz z Piły, Bydgoszczy czy okolicy, i czy chodzi o laptopa, czy komputer stacjonarny.</p>
		<ul>
			<li>Czyszczenie z kurzu i wymiana pasty termoprzewodzącej — sprzęt się przegrzewa lub głośno pracuje.</li>
			<li>Wymiana dysku HDD/SSD — poprawa szybkości działania lub awaria dysku.</li>
			<li>Wymiana matrycy laptopa — pęknięty lub uszkodzony ekran.</li>
			<li>Naprawa układu zasilania płyty głównej i lutowanie BGA.</li>
			<li>Naprawa zawiasów i obudowy laptopa — luźna lub pęknięta obudowa.</li>
			<li>Instalacja systemu operacyjnego od podstaw.</li>
			<li>Czyszczenie po zalaniu — im szybciej przyniesiesz sprzęt, tym większa szansa na pełną naprawę.</li>
			<li>Odzyskiwanie danych — podstawowe na miejscu, złożone przypadki we współpracy z zewnętrznym laboratorium.</li>
		</ul>
	</section>

	<TrustBlock lang={lang} heading="Wiemy, o co się martwisz" />

	<ProcessSteps lang={lang} heading="Jak wygląda naprawa krok po kroku" />

	<CtaBanner
		heading="Przynieś sprzęt albo wyślij zapytanie"
		body={`Bezpłatna diagnoza, wycena na piśmie, ${site.warrantyMonths} miesiące gwarancji na naprawę.`}
		ctaLabel="Darmowa wycena"
		ctaHref={contactHref}
	/>
</PageLayout>

<style>
	.services-list {
		padding-block: var(--space-7);
	}

	.services-list__note {
		color: var(--color-ink-soft);
		max-width: 62ch;
		margin-top: var(--space-3);
	}

	.services-list ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 60ch;
	}

	.services-list li {
		font-size: var(--text-lg);
	}
</style>
