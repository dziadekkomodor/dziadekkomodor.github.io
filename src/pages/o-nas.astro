---
import PageLayout from '../layouts/PageLayout.astro';
import TeamCard from '../components/TeamCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { Image } from 'astro:assets';
import { team } from '../data/team';
import { localePath } from '../data/nav';
import { site } from '../data/site';
import workshopPhoto from '../assets/photos/workshop-wide.jpg';

const lang = "pl" as const;
const title = "O nas";
const description = "Poznaj Alberta i Mikołaja — dwóch założycieli Dziadka Komodora, serwisu komputerowego w Pile, Bydgoszczy i okolicach.";
---

<PageLayout lang={lang} slug="o-nas" title={title} description={description}>
	<section class="container page-hero" data-animate="reveal">
		<h1>O nas</h1>
		<p class="page-hero__lead">
			Dziadek Komodor to nie korporacja — to dwóch ludzi, którzy naprawiają sprzęt osobiście,
			od diagnozy po test końcowy. Działamy jako niezarejestrowana działalność (w rozumieniu
			polskich przepisów o działalności nierejestrowanej) — to nie zmienia jakości naprawy,
			ale oznacza, że na razie nie wystawiamy faktur VAT.
		</p>
	</section>

	<section class="container">
		<Image
			src={workshopPhoto}
			alt="Warsztat Dziadka Komodora"
			width={1400}
			height={600}
			format="webp"
			class="workshop-photo"
		/>
	</section>

	<section class="container team-full" data-animate="reveal">
		{team.map((member) => (
			<TeamCard
				lang={lang}
				name={member.name}
				age={member.age}
				role={member.role[lang]}
				bio={member.bio[lang]}
				yearsExperience={member.yearsExperience}
				photo={member.photo}
			/>
		))}
	</section>

	<CtaBanner
		heading="Chcesz, żebyśmy zajęli się Twoim sprzętem?"
		body={`Bezpłatna diagnoza, jasna wycena, ${site.warrantyMonths} miesiące gwarancji.`}
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 68ch;
	}

	.workshop-photo {
		width: 100%;
		height: auto;
		aspect-ratio: 21 / 9;
		object-fit: cover;
		border-radius: var(--radius-soft);
	}

	.team-full {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
		padding-block: var(--space-7);
	}

	@media (min-width: 800px) {
		.team-full {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
