---
import PageLayout from '../layouts/PageLayout.astro';
import PricingTable from '../components/PricingTable.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { localePath } from '../data/nav';
import { site } from '../data/site';

const lang = "pl" as const;
const title = "Cennik napraw";
const description = "Orientacyjny cennik napraw komputerów, laptopów i telefonów w Pile, Bydgoszczy i okolicach. Bezpłatna diagnoza, jasna wycena przed każdą naprawą.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Ile kosztuje czyszczenie laptopa?",
      acceptedAnswer: { "@type": "Answer", text: "Czyszczenie laptopa z wymianą pasty termoprzewodzącej kosztuje 65–150 zł. Laptopy gamingowe od ok. 250 zł." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje wymiana baterii w telefonie?",
      acceptedAnswer: { "@type": "Answer", text: "Wymiana baterii w telefonie z Androidem: 150–199 zł. W iPhonie i flagowcach: 250–350 zł." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje wymiana wyświetlacza w telefonie?",
      acceptedAnswer: { "@type": "Answer", text: "Wymiana wyświetlacza w Androidzie: 259–329 zł. W iPhonie i flagowcach: od 600 zł (najnowsze modele do 1 610 zł)." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje instalacja Windowsa?",
      acceptedAnswer: { "@type": "Answer", text: "Instalacja systemu operacyjnego kosztuje 100–180 zł." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje wymiana matrycy w laptopie?",
      acceptedAnswer: { "@type": "Answer", text: "Wymiana matrycy 15.6\" kosztuje od ok. 370 zł. Cena zależy od modelu urządzenia i rodzaju ekranu." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje odzyskiwanie danych?",
      acceptedAnswer: { "@type": "Answer", text: "Odzyskiwanie podstawowe (logiczne) kosztuje od ok. 100 zł. Odzyskiwanie głębokie, mechaniczne lub z macierzy RAID: 300–4 500 zł (realizowane przez zewnętrzne laboratorium)." },
    },
    {
      "@type": "Question",
      name: "Ile kosztuje naprawa płyty głównej laptopa?",
      acceptedAnswer: { "@type": "Answer", text: "Naprawa układu zasilania płyty głównej: 180–350 zł. Lutowanie BGA: 200–450 zł. Naprawa BIOS: 150–280 zł." },
    },
    {
      "@type": "Question",
      name: "Czy diagnoza jest darmowa?",
      acceptedAnswer: { "@type": "Answer", text: `Diagnoza wstępna jest bezpłatna. Diagnoza szczegółowa kosztuje ${site.diagnosisDetailedFee} zł, ale kwota ta jest odliczana od ceny naprawy, jeśli zdecydujesz się na jej wykonanie.` },
    },
  ],
};
---

<PageLayout lang={lang} slug="cennik" title={title} description={description} jsonLd={jsonLd}>
	<section class="container page-hero" data-animate="reveal">
		<h1>Cennik</h1>
		<p class="page-hero__lead">
			Poniżej znajdziesz orientacyjne ceny najczęstszych napraw. Dokładną kwotę zawsze podajemy
			po bezpłatnej wstępnej diagnozie — na piśmie, przed rozpoczęciem jakiejkolwiek pracy.
		</p>
	</section>

	<section class="container">
		<PricingTable lang={lang} />
	</section>

	<section class="container transport" data-animate="reveal">
		<h2>Jak dostarczyć sprzęt</h2>
		<ul>
			<li>
				<strong>Wyślesz sam/a</strong> — koszt przesyłki jest po Twojej stronie.
			</li>
			<li>
				<strong>Dowieziesz osobiście</strong> do Wyrzyska — bezpłatnie, dokładny adres podamy po kontakcie.
			</li>
			<li>
				<strong>Odbierzemy sprzęt</strong> — koszt paliwa (dojazd do Ciebie i z powrotem) + {site.pickupFee} zł. Dostępność potwierdzamy po kontakcie — nie zawsze jest to możliwe od razu.
			</li>
		</ul>
	</section>

	<CtaBanner
		heading="Nie widzisz swojej usługi na liście?"
		body="Zadzwoń albo napisz — powiemy Ci od razu, ile orientacyjnie będzie kosztować naprawa."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}

	.transport {
		padding-block: var(--space-6);
	}

	.transport ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 62ch;
		color: var(--color-ink-soft);
	}
</style>
