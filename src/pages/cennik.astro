---
import PageLayout from '../layouts/PageLayout.astro';
import PricingTable from '../components/PricingTable.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { localePath } from '../data/nav';
import { site } from '../data/site';

const lang = "pl" as const;
const title = "Cennik napraw";
const description = "Orientacyjny cennik napraw komputerów, laptopów i telefonów w Pile i Bydgoszczy. Bezpłatna diagnoza, jasna wycena przed każdą naprawą.";
---

<PageLayout lang={lang} slug="cennik" title={title} description={description}>
	<section class="container page-hero" data-animate="reveal">
		<h1>Cennik</h1>
		<p class="page-hero__lead">
			Poniżej znajdziesz orientacyjne ceny najczęstszych napraw. Dokładną kwotę zawsze podajemy
			po bezpłatnej wstępnej diagnozie — na piśmie, przed rozpoczęciem jakiejkolwiek pracy.
		</p>
	</section>

	<section class="container">
		<PricingTable lang={lang} />
	</section>

	<section class="container transport" data-animate="reveal">
		<h2>Jak dostarczyć sprzęt</h2>
		<ul>
			<li>
				<strong>Wyślesz sam/a</strong> — koszt przesyłki jest po Twojej stronie.
			</li>
			<li>
				<strong>Dowieziesz osobiście</strong> do Wyrzyska — bezpłatnie, dokładny adres podamy po kontakcie.
			</li>
			<li>
				<strong>Odbierzemy sprzęt</strong> — koszt paliwa (dojazd do Ciebie i z powrotem) + {site.pickupFee} zł. Dostępność potwierdzamy po kontakcie — nie zawsze jest to możliwe od razu.
			</li>
		</ul>
	</section>

	<CtaBanner
		heading="Nie widzisz swojej usługi na liście?"
		body="Zadzwoń albo napisz — powiemy Ci od razu, ile orientacyjnie będzie kosztować naprawa."
		ctaLabel="Darmowa wycena"
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.page-hero {
		padding-block: var(--space-6) var(--space-5);
	}

	.page-hero__lead {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}

	.transport {
		padding-block: var(--space-6);
	}

	.transport ul {
		margin-top: var(--space-4);
		padding-left: 1.2em;
		display: grid;
		gap: var(--space-3);
		max-width: 62ch;
		color: var(--color-ink-soft);
	}
</style>
