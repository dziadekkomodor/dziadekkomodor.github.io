---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBlock from '../components/TrustBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TeamCard from '../components/TeamCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { site } from '../data/site';
import { services } from '../data/services';
import { team } from '../data/team';
import { homeCopy } from '../data/copy/index';
import { localePath } from '../data/nav';
import heroPhoto from '../assets/photos/hero-team.jpg';

const lang = "pl" as const;
const c = homeCopy;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.url}/#firma`,
  name: site.brandName,
  image: `${site.url}/img/serwis.jpg`,
  url: site.url,
  telephone: site.phone.href.replace("tel:", ""),
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: site.addressLocality,
    addressRegion: site.addressRegion,
    addressCountry: site.addressCountry,
  },
  areaServed: site.serviceAreas.map((name) => ({ "@type": "City", name })),
  openingHoursSpecification: site.hours.map((h) => ({
    "@type": "OpeningHoursSpecification",
    dayOfWeek: h.days,
    opens: h.opens,
    closes: h.closes,
  })),
  sameAs: [site.socials.facebook, site.socials.googleBusiness],
};
---

<PageLayout lang={lang} slug="" title={c.hero.headline.pl} description={c.metaDescription.pl} jsonLd={jsonLd}>
	<Hero
		lang={lang}
		eyebrow={c.hero.eyebrow[lang]}
		headline={c.hero.headline[lang]}
		subhead={c.hero.subhead[lang]}
		ctaLabel={c.hero.ctaPrimary[lang]}
		ctaHref={localePath(lang, "kontakt")}
		photoCaptionPl="Zdjęcie Alberta, Mikołaja i warsztatu — do dodania"
		photoCaptionEn="Photo of Albert, Mikołaj, and the workshop — to be added"
		photo={heroPhoto}
	/>

	<section class="container routing" data-animate="reveal">
		<h2>{c.routing.heading[lang]}</h2>
		<p class="routing__intro">{c.routing.intro[lang]}</p>
		<div class="routing__grid">
			{services.map((s, i) => (
				<ServiceCard
					href={localePath(lang, s.slug)}
					persona={s.persona[lang]}
					title={s.title[lang]}
					short={s.short[lang]}
					featured={i === 0}
					theme={s.theme}
				/>
			))}
		</div>
	</section>

	<TrustBlock lang={lang} heading={c.trust.heading[lang]} intro={c.trust.intro[lang]} />

	<ProcessSteps lang={lang} heading={c.process.heading[lang]} />

	<section class="container team-preview" data-animate="reveal">
		<h2>{c.team.heading[lang]}</h2>
		<p class="routing__intro">{c.team.intro[lang]}</p>
		<div class="team-preview__grid">
			{team.map((member) => (
				<TeamCard
					lang={lang}
					name={member.name}
					age={member.age}
					role={member.role[lang]}
					bio={member.bio[lang]}
					yearsExperience={member.yearsExperience}
					photo={member.photo}
					compact
				/>
			))}
		</div>
		<a href={localePath(lang, "o-nas")} class="team-preview__link">{c.team.ctaLabel[lang]} →</a>
	</section>

	<CtaBanner
		heading={c.ctaBanner.heading[lang]}
		body={c.ctaBanner.body[lang]}
		ctaLabel={c.hero.ctaPrimary[lang]}
		ctaHref={localePath(lang, "kontakt")}
	/>
</PageLayout>

<style>
	.routing {
		padding-block: var(--space-7);
	}

	.routing__intro {
		font-size: var(--text-lg);
		color: var(--color-ink-soft);
		max-width: 60ch;
	}

	.routing__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		margin-top: var(--space-5);
	}

	.team-preview {
		padding-block: var(--space-7);
	}

	.team-preview__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-5);
		margin-top: var(--space-5);
		max-width: 40rem;
	}

	.team-preview__link {
		display: inline-block;
		margin-top: var(--space-5);
		font-weight: var(--weight-body-bold);
		text-decoration: none;
	}

	@media (min-width: 700px) {
		.team-preview__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 900px) {
		.routing__grid {
			grid-template-columns: repeat(6, 1fr);
			grid-auto-rows: minmax(180px, auto);
		}

		.routing__grid > :global(a:nth-child(1)) {
			grid-column: 1 / 5;
			grid-row: 1 / 3;
		}

		.routing__grid > :global(a:nth-child(2)) {
			grid-column: 5 / 7;
			grid-row: 1 / 2;
		}

		.routing__grid > :global(a:nth-child(3)) {
			grid-column: 5 / 7;
			grid-row: 2 / 3;
		}

		.routing__grid > :global(a:nth-child(4)) {
			grid-column: 1 / 4;
			grid-row: 3 / 4;
		}

		.routing__grid > :global(a:nth-child(5)) {
			grid-column: 4 / 7;
			grid-row: 3 / 4;
		}
	}
</style>
